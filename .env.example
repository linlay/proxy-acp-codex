# Local HTTP port for proxy-acp-codex.
PROXY_ACP_PORT=3211

# Listen address; uncomment and set to 0.0.0.0 only when remote access is required.
# PROXY_ACP_ADDR=

# Optional bearer token; leave commented to disable auth.
# PROXY_ACP_AUTH_TOKEN=

# Codex CLI command or absolute path.
# CODEX_CLI=codex

# Codex backend. app-server enables true streaming; exec-json keeps the legacy adapter.
# CODEX_BACKEND=app-server

# Extra arguments passed to codex app-server.
CODEX_APP_SERVER_ARGS="--enable network_proxy"

# Extra arguments passed to codex exec before the prompt when CODEX_BACKEND=exec-json.
# CODEX_ARGS="--model gpt-5"

# Optional network proxy inherited by Codex CLI backend.
# http_proxy=http://127.0.0.1:8001
# HTTP_PROXY=http://127.0.0.1:8001
# https_proxy=http://127.0.0.1:8001
# HTTPS_PROXY=http://127.0.0.1:8001

# Idle ACP session timeout in milliseconds.
# PROXY_ACP_IDLE_TIMEOUT_MS=1800000
